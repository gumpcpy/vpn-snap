# 全域設定（所有線路共用）
# 複製此檔為 ~/.config/vpn-mac/config.env 後修改

# 預設使用的線路名稱（對應 profiles/<名稱>.env）
ACTIVE_PROFILE="primary"

# Keychain 項目名稱（用 setup-keychain.sh 建立）
KEYCHAIN_SERVICE="vpn-mac"

# Cisco CLI 路徑
VPN_BIN="/opt/cisco/secureclient/bin/vpn"

# 若 VPN 需要二次驗證，填選項編號（例如 2 = Okta Push）
MFA_OPTION=""

# 伺服器憑證不受信任時（例如用 IP 連線）
TRUST_SERVER_CERT="y"
IMPORT_SERVER_CERT="y"

# 連線後其他互動提示（通常填 y）
AUTO_CONFIRM="y"

# ── 舊版相容（建議改用 profiles/ 管理多條線路）──
# VPN_HOST="vpn.example.com"
# VPN_USER="your.username"
